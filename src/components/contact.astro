---
const contactOptions = [
  {
    title: "Diagnóstico de infraestructura",
    description:
      "Revisamos tu red, cableado, equipos, racks y operación actual para detectar qué se puede mejorar.",
    tag: "Recomendado",
  },
  {
    title: "Cotización de proyecto",
    description:
      "Cuéntanos qué necesitas instalar, organizar o configurar y preparamos una propuesta clara.",
    tag: "Proyecto",
  },
  {
    title: "Soporte técnico",
    description:
      "Si tienes fallas de red, equipos desconectados o problemas técnicos, podemos ayudarte a revisarlo.",
    tag: "Soporte",
  },
];

const contactInfo = [
  {
    label: "WhatsApp",
    value: "Enviar mensaje directo",
    href: "https://wa.me/526142414255",
  },
  {
    label: "Correo",
    value: "info@procodedev.com",
    href: "mailto:info@procodedev.com",
  },
  {
    label: "Ubicación",
    value: "Durango, México",
    href: "#",
  },
];
---

<section
  id="contacto"
  class="relative overflow-hidden bg-[#020817] py-20 text-white scroll-mt-32 sm:py-24 lg:py-28"
>
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(37,99,235,0.16),transparent_38%),radial-gradient(circle_at_bottom_right,rgba(31,79,134,0.16),transparent_40%)]"
    >
    </div>
    <div
      class="absolute left-1/2 top-0 h-px w-[72%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
  >
    <!-- CTA principal -->
    <div
      class="relative overflow-hidden rounded-[34px] border border-blue-300/15 bg-[#061126]/75 p-6 shadow-[0_0_65px_rgba(37,99,235,0.18)] backdrop-blur-xl sm:p-8 lg:p-12"
    >
      <div class="pointer-events-none absolute inset-0">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.20),transparent_38%)]"
        >
        </div>
        <div
          class="absolute bottom-0 left-1/2 h-px w-[80%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"
        >
        </div>
      </div>

      <div
        class="relative grid gap-12 lg:grid-cols-[1fr_0.9fr] lg:items-center"
      >
        <!-- Texto principal -->
        <div>
          <div
            class="mb-6 inline-flex items-center gap-3 rounded-full border border-blue-400/20 bg-blue-500/5 px-4 py-2 shadow-[0_0_24px_rgba(37,99,235,0.12)] backdrop-blur-xl"
          >
            <span
              class="h-2 w-2 rounded-full bg-blue-400 shadow-[0_0_14px_rgba(96,165,250,1)]"
            ></span>
            <span
              class="text-[10px] font-semibold uppercase tracking-[0.22em] text-blue-300 sm:text-xs sm:tracking-[0.32em]"
            >
              Agenda una revisión técnica
            </span>
          </div>

          <h2
            class="max-w-4xl text-3xl font-bold tracking-[-0.04em] text-white sm:text-4xl md:text-5xl lg:text-6xl"
          >
            ¿Tu negocio necesita una red más estable, ordenada y profesional?
          </h2>

          <p
            class="mt-6 max-w-3xl text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
          >
            En ProCode Systems podemos ayudarte a revisar tu infraestructura
            actual, detectar puntos débiles y proponerte una solución clara para
            mejorar conectividad, organización técnica y operación interna.
          </p>

          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a
              href="https://wa.me/526142414255"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-7 py-4 text-sm font-bold text-white shadow-[0_0_34px_rgba(37,99,235,0.40)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400 hover:shadow-[0_0_48px_rgba(59,130,246,0.62)]"
            >
              Contactar por WhatsApp

              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 12h14"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m12 5 7 7-7 7"></path>
              </svg>
            </a>

            <a
              href="mailto:info@procodedev.com"
              class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.03] px-7 py-4 text-sm font-semibold text-white shadow-inner shadow-white/5 backdrop-blur-xl transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300/30 hover:bg-blue-500/10"
            >
              Enviar correo
            </a>
          </div>
        </div>

        <!-- Panel visual derecho -->
        <div
          class="relative overflow-hidden rounded-[28px] border border-white/10 bg-[#020817]/65 p-5 shadow-[0_0_45px_rgba(37,99,235,0.14)] sm:p-6"
        >
          <div
            class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.20),transparent_42%)]"
          >
          </div>

          <div
            class="relative flex items-center gap-3 border-b border-white/10 pb-5"
          >
            <img
              src="/Logo/Logofondoazul.webp"
              alt="ProCode Systems"
              class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
            />

            <div>
              <p class="text-lg font-bold text-white">ProCode Systems</p>
              <p class="text-sm text-slate-400">Contacto técnico</p>
            </div>
          </div>

          <div class="relative mt-5 grid gap-4">
            {
              contactOptions.map((option) => (
                <div class="rounded-[22px] border border-white/10 bg-white/[0.035] p-5 transition-all duration-300 hover:border-blue-300/30 hover:bg-blue-500/10">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-base font-bold text-white">
                        {option.title}
                      </h3>

                      <p class="mt-2 text-sm leading-6 text-slate-400">
                        {option.description}
                      </p>
                    </div>

                    <span class="shrink-0 rounded-full border border-blue-300/20 bg-blue-500/10 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-blue-300">
                      {option.tag}
                    </span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <!-- Información de contacto -->
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {
        contactInfo.map((item) => (
          <a
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : "_self"}
            rel={
              item.href.startsWith("http") ? "noopener noreferrer" : undefined
            }
            class="group rounded-[24px] border border-white/10 bg-[#061126]/65 p-6 shadow-[0_0_35px_rgba(37,99,235,0.10)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/30 hover:bg-[#071A33]/80"
          >
            <p class="text-xs font-semibold uppercase tracking-[0.26em] text-blue-300">
              {item.label}
            </p>

            <div class="mt-4 flex items-center justify-between gap-4">
              <p class="text-lg font-bold text-white">{item.value}</p>

              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-blue-300/20 bg-blue-500/10 text-blue-300 transition-transform duration-300 group-hover:translate-x-1">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 12h14"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m12 5 7 7-7 7"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
