---
const projects = [
  {
    label: "Oficinas y negocios",
    title: "Red empresarial para operación diaria",
    description:
      "Diseño de red para áreas administrativas, estaciones de trabajo, impresoras, cámaras y puntos de acceso WiFi.",
    items: ["Puntos de red", "WiFi empresarial", "Equipos organizados"],
  },
  {
    label: "Infraestructura técnica",
    title: "Rack organizado y cableado estructurado",
    description:
      "Ordenamiento de routers, switches, patch panels, cableado y distribución técnica para facilitar mantenimiento y crecimiento.",
    items: ["Rack limpio", "Cableado etiquetado", "Mantenimiento simple"],
  },
  {
    label: "Operación digital",
    title: "Procesos internos más claros",
    description:
      "Estructura digital para organizar tareas, seguimiento de clientes, control de actividades y flujos de trabajo internos.",
    items: ["Procesos definidos", "Control operativo", "Menos improvisación"],
  },
];

const metrics = [
  { value: "01", label: "Diagnóstico" },
  { value: "02", label: "Planeación" },
  { value: "03", label: "Implementación" },
  { value: "04", label: "Soporte" },
];
---

<section
  id="portafolio"
  class="relative overflow-hidden bg-[#020817] py-20 text-white sm:py-24 lg:py-28 scroll-mt-32"
>
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.13),transparent_35%),radial-gradient(circle_at_bottom_left,rgba(31,79,134,0.14),transparent_38%)]"
    >
    </div>
    <div
      class="absolute left-1/2 top-0 h-px w-[72%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
  >
    <!-- Encabezado -->
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-300"
        >
          Soluciones en acción
        </p>

        <h2
          class="mt-4 max-w-3xl text-3xl font-bold tracking-[-0.03em] text-white sm:text-4xl md:text-5xl"
        >
          Infraestructura pensada para negocios que necesitan operar sin
          desorden técnico.
        </h2>
      </div>

      <p
        class="max-w-2xl text-sm leading-7 text-slate-300 sm:text-base sm:leading-8 lg:ml-auto"
      >
        Cada negocio tiene necesidades distintas. Por eso no trabajamos con
        soluciones genéricas: revisamos el espacio, entendemos la operación y
        construimos una base tecnológica que conecte personas, equipos y
        procesos.
      </p>
    </div>

    <!-- Bloque principal -->
    <div class="mt-14 grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <!-- Mockup visual grande -->
      <div
        class="relative overflow-hidden rounded-[30px] border border-blue-300/15 bg-[#061126]/70 p-5 shadow-[0_0_55px_rgba(37,99,235,0.16)] backdrop-blur-xl sm:p-6 lg:p-8"
      >
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.18),transparent_42%)]"
        >
        </div>

        <!-- Top bar -->
        <div
          class="relative flex flex-col gap-4 border-b border-white/10 pb-5 sm:flex-row sm:items-center sm:justify-between"
        >
          <div class="flex items-center gap-3">
            <img
              src="/Logo/Logofondoazul.webp"
              alt="ProCode Systems"
              class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
            />

            <div>
              <p class="text-lg font-bold text-white">ProCode Systems</p>
              <p class="text-sm text-slate-400">
                Panel de infraestructura tecnológica
              </p>
            </div>
          </div>

          <div
            class="inline-flex w-fit items-center gap-2 rounded-full border border-green-400/20 bg-green-400/10 px-3 py-1.5 text-xs font-semibold text-green-300"
          >
            <span
              class="h-2 w-2 rounded-full bg-green-400 shadow-[0_0_12px_rgba(74,222,128,0.9)]"
            ></span>
            Sistema activo
          </div>
        </div>

        <!-- Dashboard -->
        <div class="relative mt-6 grid gap-5 lg:grid-cols-[0.75fr_1.25fr]">
          <!-- Sidebar visual -->
          <div
            class="rounded-[24px] border border-white/10 bg-[#020817]/55 p-4"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-300"
            >
              Módulos
            </p>

            <div class="mt-5 space-y-3">
              <div
                class="rounded-2xl border border-blue-300/20 bg-blue-500/10 p-4"
              >
                <p class="text-sm font-bold text-white">Red</p>
                <p class="mt-1 text-xs text-slate-400">Conectividad estable</p>
              </div>

              <div
                class="rounded-2xl border border-white/10 bg-white/[0.03] p-4"
              >
                <p class="text-sm font-bold text-white">Rack</p>
                <p class="mt-1 text-xs text-slate-400">Equipos organizados</p>
              </div>

              <div
                class="rounded-2xl border border-white/10 bg-white/[0.03] p-4"
              >
                <p class="text-sm font-bold text-white">Procesos</p>
                <p class="mt-1 text-xs text-slate-400">Flujos internos</p>
              </div>
            </div>
          </div>

          <!-- Main panel -->
          <div
            class="rounded-[24px] border border-white/10 bg-[#020817]/55 p-4 sm:p-5"
          >
            <div class="grid gap-3 sm:grid-cols-4">
              {
                metrics.map((metric) => (
                  <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
                    <p class="text-2xl font-black text-white">{metric.value}</p>
                    <p class="mt-1 text-xs text-slate-400">{metric.label}</p>
                  </div>
                ))
              }
            </div>

            <!-- Network visual -->
            <div
              class="mt-5 rounded-2xl border border-white/10 bg-[#061126]/70 p-5"
            >
              <div class="mb-5 flex items-center justify-between">
                <div>
                  <p
                    class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-300"
                  >
                    Mapa de conexión
                  </p>
                  <p class="mt-1 text-sm text-slate-400">
                    Equipos conectados y operación estable
                  </p>
                </div>

                <span
                  class="rounded-full bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-300"
                >
                  Online
                </span>
              </div>

              <div
                class="relative min-h-[220px] overflow-hidden rounded-2xl border border-white/10 bg-[#020817]/70 p-5"
              >
                <div
                  class="absolute left-1/2 top-1/2 h-20 w-20 -translate-x-1/2 -translate-y-1/2 rounded-full border border-blue-300/30 bg-blue-500/10 shadow-[0_0_45px_rgba(37,99,235,0.4)]"
                >
                </div>

                <div
                  class="absolute left-1/2 top-1/2 h-px w-[70%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/60 to-transparent"
                >
                </div>
                <div
                  class="absolute left-1/2 top-1/2 h-[70%] w-px -translate-y-1/2 bg-gradient-to-b from-transparent via-blue-400/50 to-transparent"
                >
                </div>

                <div
                  class="absolute left-[12%] top-[18%] h-10 w-10 rounded-xl border border-blue-300/20 bg-blue-500/10 shadow-[0_0_20px_rgba(37,99,235,0.25)]"
                >
                </div>
                <div
                  class="absolute right-[12%] top-[18%] h-10 w-10 rounded-xl border border-blue-300/20 bg-blue-500/10 shadow-[0_0_20px_rgba(37,99,235,0.25)]"
                >
                </div>
                <div
                  class="absolute bottom-[16%] left-[18%] h-10 w-10 rounded-xl border border-blue-300/20 bg-blue-500/10 shadow-[0_0_20px_rgba(37,99,235,0.25)]"
                >
                </div>
                <div
                  class="absolute bottom-[16%] right-[18%] h-10 w-10 rounded-xl border border-blue-300/20 bg-blue-500/10 shadow-[0_0_20px_rgba(37,99,235,0.25)]"
                >
                </div>

                <div
                  class="absolute left-1/2 top-1/2 flex h-14 w-14 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-2xl border border-blue-300/30 bg-[#1F4F86]"
                >
                  <img
                    src="/Logo/Logofondoazul.webp"
                    alt="ProCode Systems"
                    class="h-14 w-14 rounded-full object-contain"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Cards de casos -->
      <div class="grid gap-5">
        {
          projects.map((project, index) => (
            <article class="group relative overflow-hidden rounded-[26px] border border-white/10 bg-[#061126]/70 p-6 shadow-[0_0_40px_rgba(37,99,235,0.10)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/30 hover:bg-[#071A33]/85 hover:shadow-[0_0_55px_rgba(37,99,235,0.22)]">
              <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <div class="absolute -right-20 -top-20 h-44 w-44 rounded-full bg-blue-500/15 blur-[70px]" />
              </div>

              <div class="relative z-10 flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-300">
                    {project.label}
                  </p>

                  <h3 class="mt-3 text-xl font-bold text-white sm:text-2xl">
                    {project.title}
                  </h3>
                </div>

                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-blue-300/20 bg-blue-500/10 text-sm font-black text-blue-300">
                  0{index + 1}
                </div>
              </div>

              <p class="relative z-10 mt-4 text-sm leading-7 text-slate-400">
                {project.description}
              </p>

              <div class="relative z-10 mt-5 flex flex-wrap gap-2">
                {project.items.map((item) => (
                  <span class="rounded-full border border-white/10 bg-white/[0.035] px-3 py-1.5 text-xs font-semibold text-slate-300">
                    {item}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
