---
const steps = [
  {
    number: "01",
    title: "Diagnóstico inicial",
    description:
      "Revisamos tu espacio, operación, cantidad de usuarios, equipos actuales, puntos de conexión y problemas que estás enfrentando.",
    detail: "Entendemos antes de proponer.",
  },
  {
    number: "02",
    title: "Diseño de solución",
    description:
      "Definimos qué red, cableado, rack, equipos, configuración o proceso digital necesita realmente tu negocio.",
    detail: "Planeamos con estructura.",
  },
  {
    number: "03",
    title: "Instalación ordenada",
    description:
      "Ejecutamos la instalación de cableado, organización técnica, montaje de equipos y configuración necesaria para dejar todo funcional.",
    detail: "Implementamos con orden.",
  },
  {
    number: "04",
    title: "Configuración y pruebas",
    description:
      "Validamos conectividad, estabilidad, velocidad, distribución de red y funcionamiento correcto de cada punto o dispositivo.",
    detail: "Probamos antes de entregar.",
  },
  {
    number: "05",
    title: "Entrega y soporte",
    description:
      "Te explicamos cómo queda tu infraestructura, qué se instaló, cómo funciona y qué recomendaciones seguir para mantenerla estable.",
    detail: "Acompañamos después de entregar.",
  },
];
---

<section id="proceso" class="relative overflow-hidden bg-[#020817] py-20 text-white sm:py-24 lg:py-28 scroll-mt-32">
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.12),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(31,79,134,0.16),transparent_38%)]"></div>
    <div class="absolute left-1/2 top-0 h-px w-[72%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"></div>
  </div>

  <div class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]">
    
    <!-- Encabezado -->
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-300">
        Nuestro proceso
      </p>

      <h2 class="mt-4 text-3xl font-bold tracking-[-0.03em] text-white sm:text-4xl md:text-5xl">
        De un problema técnico a una infraestructura clara, estable y funcional.
      </h2>

      <p class="mt-5 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8">
        Trabajamos con una metodología simple pero sólida: primero entendemos tu operación, después diseñamos la solución correcta y finalmente implementamos con orden técnico.
      </p>
    </div>

    <!-- Timeline desktop -->
    <div class="relative mt-16 hidden lg:block">
      <!-- Línea horizontal -->
      <div class="absolute left-0 right-0 top-[46px] h-px bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"></div>

      <div class="grid grid-cols-5 gap-5">
        {steps.map((step) => (
          <article class="group relative">
            <!-- Número -->
            <div class="relative z-10 mx-auto flex h-[92px] w-[92px] items-center justify-center rounded-full border border-blue-300/20 bg-[#061126] shadow-[0_0_35px_rgba(37,99,235,0.22)] transition-all duration-300 group-hover:scale-105 group-hover:border-blue-300/40 group-hover:shadow-[0_0_50px_rgba(37,99,235,0.38)]">
              <div class="absolute inset-2 rounded-full bg-blue-500/10"></div>
              <span class="relative text-xl font-black text-blue-300">
                {step.number}
              </span>
            </div>

            <!-- Card -->
            <div class="mt-8 min-h-[260px] rounded-[24px] border border-white/10 bg-[#061126]/65 p-6 text-center shadow-[0_0_40px_rgba(37,99,235,0.10)] backdrop-blur-xl transition-all duration-300 group-hover:-translate-y-1 group-hover:border-blue-300/30 group-hover:bg-[#071A33]/80 group-hover:shadow-[0_0_55px_rgba(37,99,235,0.22)]">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-300">
                {step.detail}
              </p>

              <h3 class="mt-4 text-xl font-bold text-white">
                {step.title}
              </h3>

              <p class="mt-4 text-sm leading-7 text-slate-400">
                {step.description}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Timeline mobile/tablet -->
    <div class="relative mt-12 grid gap-5 lg:hidden">
      <div class="absolute bottom-0 left-7 top-0 w-px bg-gradient-to-b from-blue-400/40 via-blue-500/20 to-transparent"></div>

      {steps.map((step) => (
        <article class="relative grid grid-cols-[56px_1fr] gap-4">
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full border border-blue-300/20 bg-[#061126] shadow-[0_0_30px_rgba(37,99,235,0.24)]">
            <span class="text-sm font-black text-blue-300">
              {step.number}
            </span>
          </div>

          <div class="rounded-[22px] border border-white/10 bg-[#061126]/70 p-5 shadow-[0_0_35px_rgba(37,99,235,0.10)] backdrop-blur-xl">
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-blue-300 sm:text-xs">
              {step.detail}
            </p>

            <h3 class="mt-3 text-lg font-bold text-white sm:text-xl">
              {step.title}
            </h3>

            <p class="mt-3 text-sm leading-7 text-slate-400">
              {step.description}
            </p>
          </div>
        </article>
      ))}
    </div>

    <!-- Bloque inferior -->
    <div class="mt-14 overflow-hidden rounded-[28px] border border-blue-300/15 bg-[#061126]/65 shadow-[0_0_45px_rgba(37,99,235,0.14)] backdrop-blur-xl">
      <div class="grid items-center gap-8 p-6 sm:p-8 lg:grid-cols-[0.9fr_1.1fr] lg:p-10">
        
        <!-- Visual técnico -->
        <div class="relative min-h-[260px] overflow-hidden rounded-[24px] border border-white/10 bg-[#020817]/70 p-5">
          <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(37,99,235,0.22),transparent_48%)]"></div>

          <div class="relative grid h-full grid-cols-2 gap-4">
            <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
              <div class="mb-4 flex items-center justify-between">
                <span class="text-xs font-semibold text-blue-300">Rack</span>
                <span class="h-2 w-2 rounded-full bg-green-400 shadow-[0_0_12px_rgba(74,222,128,0.9)]"></span>
              </div>

              <div class="space-y-3">
                <div class="h-7 rounded-lg border border-blue-300/15 bg-blue-500/10"></div>
                <div class="h-7 rounded-lg border border-blue-300/15 bg-blue-500/10"></div>
                <div class="h-7 rounded-lg border border-blue-300/15 bg-blue-500/10"></div>
                <div class="h-7 rounded-lg border border-blue-300/15 bg-blue-500/10"></div>
              </div>
            </div>

            <div class="flex flex-col justify-between gap-4">
              <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
                <p class="text-xs font-semibold text-blue-300">Network Status</p>
                <p class="mt-2 text-2xl font-black text-white">Online</p>
                <p class="mt-1 text-xs text-slate-400">Conectividad estable</p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
                <p class="text-xs font-semibold text-blue-300">Process</p>
                <p class="mt-2 text-2xl font-black text-white">Optimized</p>
                <p class="mt-1 text-xs text-slate-400">Operación ordenada</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Texto -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-300">
            Metodología ProCode
          </p>

          <h3 class="mt-3 text-2xl font-bold tracking-[-0.03em] text-white sm:text-3xl lg:text-4xl">
            No instalamos por instalar. Creamos una base tecnológica pensada para operar mejor.
          </h3>

          <p class="mt-5 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8">
            Una red mal planeada, cables desordenados, equipos sin estructura o procesos improvisados terminan costando tiempo, dinero y estabilidad. Nuestro enfoque es construir una infraestructura clara desde el inicio.
          </p>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a
              href="#contacto"
              class="group inline-flex items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-6 py-3.5 text-sm font-bold text-white shadow-[0_0_30px_rgba(37,99,235,0.38)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400"
            >
              Agendar diagnóstico
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
                <path stroke-linecap="round" stroke-linejoin="round" d="m12 5 7 7-7 7" />
              </svg>
            </a>

            <a
              href="#contacto"
              class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.03] px-6 py-3.5 text-sm font-semibold text-white transition-all duration-300 hover:border-blue-300/30 hover:bg-blue-500/10"
            >
              Hablar con ProCode
            </a>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>