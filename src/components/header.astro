---
const navItems = [
  { label: "Inicio", href: "/#inicio" },
  { label: "Servicios", href: "/#servicios" },
  { label: "Proceso", href: "/#proceso" },
  { label: "Portafolio", href: "/#portafolio" },
  { label: "Nosotros", href: "/#nosotros" },
  { label: "Blog", href: "/#blog" },
  { label: "Contacto", href: "/#contacto" },
];
---

<header class="fixed left-0 top-0 z-50 w-full">
  <div
    class="mx-auto w-full max-w-[1480px] px-4 pt-4 sm:px-6 sm:pt-5 lg:px-10 2xl:max-w-[1600px]"
  >
    <nav
      class="relative flex h-[70px] items-center justify-between overflow-hidden rounded-[20px] border border-white/10 bg-[#020817]/95 px-4 shadow-[0_0_45px_rgba(37,99,235,0.18)] backdrop-blur-xl sm:h-[76px] sm:px-5 lg:h-[78px] lg:px-7"
    >
      <!-- Fondo interno -->
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.20),transparent_32%),linear-gradient(90deg,rgba(2,8,23,0.98),rgba(5,18,40,0.96),rgba(2,8,23,0.98))]"
      >
      </div>

      <!-- Glow superior -->
      <div
        class="pointer-events-none absolute inset-x-8 top-0 h-px bg-gradient-to-r from-transparent via-blue-400/70 to-transparent"
      >
      </div>

      <!-- Glow inferior -->
      <div
        class="pointer-events-none absolute inset-x-12 bottom-0 h-px bg-gradient-to-r from-transparent via-blue-500/25 to-transparent"
      >
      </div>

      <!-- Logo -->
      <a href="/#inicio" class="relative z-10 flex items-center gap-3">
        <div
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-[#1F4F86] shadow-[0_0_24px_rgba(59,130,246,0.35)] ring-1 ring-blue-300/20 sm:h-[52px] sm:w-[52px]"
        >
          <img
            src="/Logo/Logofondoazul.webp"
            alt="ProCode Systems"
            class="h-11 w-11 rounded-full object-contain sm:h-[52px] sm:w-[52px]"
          />
        </div>

        <div class="hidden leading-none xs:block sm:block">
          <p
            class="text-[18px] font-bold tracking-tight text-white sm:text-[22px]"
          >
            ProCode
          </p>
          <p
            class="mt-1 text-[8px] font-semibold uppercase tracking-[0.34em] text-blue-100/90 sm:text-[10px] sm:tracking-[0.42em]"
          >
            Systems
          </p>
        </div>
      </a>

      <!-- Menú desktop -->
      <ul class="relative z-10 hidden items-center gap-5 lg:flex xl:gap-7">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                data-nav-link
                class="group relative text-[13px] font-semibold text-slate-300/90 transition-colors duration-300 hover:text-white"
              >
                {item.label}

                <span
                  data-nav-line
                  class="absolute -bottom-[14px] left-1/2 h-[2px] w-0 -translate-x-1/2 rounded-full bg-blue-400 shadow-[0_0_14px_rgba(96,165,250,1)] transition-all duration-300 group-hover:w-8"
                />

                <span
                  data-nav-glow
                  class="absolute -bottom-[17px] left-1/2 h-5 w-0 -translate-x-1/2 rounded-full bg-blue-500/20 blur-md transition-all duration-300 group-hover:w-10"
                />
              </a>
            </li>
          ))
        }
      </ul>

      <!-- CTA desktop -->
      <div class="relative z-10 hidden lg:block">
        <a
          href="/#contacto"
          class="group inline-flex items-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-5 py-3 text-[13px] font-bold text-white shadow-[0_0_30px_rgba(37,99,235,0.42)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400 hover:shadow-[0_0_42px_rgba(59,130,246,0.65)] xl:px-6 xl:py-3.5"
        >
          Cotizar proyecto

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Botón mobile/tablet -->
      <button
        id="menuButton"
        class="relative z-10 flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/[0.04] text-white shadow-inner shadow-white/5 transition-colors duration-300 hover:bg-white/10 lg:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg
          id="openIcon"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16"
          ></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16"
          ></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 17h16"
          ></path>
        </svg>

        <svg
          id="closeIcon"
          xmlns="http://www.w3.org/2000/svg"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6"
          ></path>
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12"
          ></path>
        </svg>
      </button>
    </nav>

    <!-- Menú mobile/tablet -->
    <div
      id="mobileMenu"
      class="hidden overflow-hidden rounded-[20px] border border-white/10 bg-[#020817]/95 shadow-[0_0_40px_rgba(37,99,235,0.22)] backdrop-blur-xl lg:hidden"
    >
      <div class="relative p-4">
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.18),transparent_42%)]"
        >
        </div>

        <ul class="relative z-10 grid gap-1 sm:grid-cols-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  data-nav-link
                  class="block rounded-xl px-4 py-3 text-sm font-semibold text-slate-300 transition-all duration-300 hover:bg-blue-500/10 hover:text-white"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="relative z-10 mt-4 border-t border-white/10 pt-4">
          <a
            href="/#contacto"
            class="group inline-flex w-full items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-5 py-3.5 text-sm font-bold text-white shadow-[0_0_30px_rgba(37,99,235,0.42)] transition-all duration-300 hover:from-blue-500 hover:to-blue-400"
          >
            Cotizar proyecto

            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m12 5 7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const menuButton = document.getElementById(
    "menuButton",
  ) as HTMLButtonElement | null;
  const mobileMenu = document.getElementById(
    "mobileMenu",
  ) as HTMLDivElement | null;
  const openIcon = document.getElementById("openIcon") as SVGElement | null;
  const closeIcon = document.getElementById("closeIcon") as SVGElement | null;

  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");

  const getHashFromHref = (href: string | null) => {
    if (!href) return "";

    try {
      const url = new URL(href, window.location.origin);
      return url.hash;
    } catch {
      return href.startsWith("#") ? href : "";
    }
  };

  const setActiveLink = (activeHref: string) => {
    navLinks.forEach((link) => {
      const href = link.getAttribute("href");
      const linkHash = getHashFromHref(href);
      const line = link.querySelector<HTMLSpanElement>("[data-nav-line]");
      const glow = link.querySelector<HTMLSpanElement>("[data-nav-glow]");

      const isActive = linkHash === activeHref;

      link.classList.toggle("text-white", isActive);
      link.classList.toggle("text-slate-300/90", !isActive);

      line?.classList.toggle("w-8", isActive);
      line?.classList.toggle("w-0", !isActive);

      glow?.classList.toggle("w-10", isActive);
      glow?.classList.toggle("w-0", !isActive);

      if (window.innerWidth < 1024) {
        link.classList.toggle("bg-blue-500/10", isActive);
      }
    });
  };

  menuButton?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.toggle("hidden") === false;

    menuButton.setAttribute("aria-expanded", String(isOpen));
    openIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  });

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      const href = link.getAttribute("href");
      const hash = getHashFromHref(href);

      if (hash) {
        setActiveLink(hash);
      }

      mobileMenu?.classList.add("hidden");
      menuButton?.setAttribute("aria-expanded", "false");
      openIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    });
  });

  const sections = document.querySelectorAll<HTMLElement>("section[id]");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActiveLink(`#${entry.target.id}`);
        }
      });
    },
    {
      rootMargin: "-35% 0px -55% 0px",
      threshold: 0,
    },
  );

  sections.forEach((section) => observer.observe(section));

  const pathname = window.location.pathname;

  if (pathname.startsWith("/servicios")) {
    setActiveLink("#servicios");
  } else if (pathname.startsWith("/blog")) {
    setActiveLink("#blog");
  } else if (window.location.hash) {
    setActiveLink(window.location.hash);
  } else {
    setActiveLink("#inicio");
  }
</script>
