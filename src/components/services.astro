---
const services = [
  {
    title: "Redes e internet empresarial",
    href: "/servicios/redes-empresariales",
    description:
      "Diseñamos y configuramos redes estables para oficinas, negocios y espacios de trabajo que necesitan conexión confiable.",
    icon: "network",
  },
  {
    title: "Cableado estructurado",
    href: "/servicios/cableado-estructurado",
    description:
      "Instalación y organización de cableado de red para mantener una infraestructura limpia, funcional y preparada para crecer.",
    icon: "cable",
  },
  {
    title: "Racks y organización técnica",
    href: "/servicios/racks-organizacion",
    description:
      "Montaje, orden y distribución de equipos de red, switches, routers, patch panels y cableado dentro de racks profesionales.",
    icon: "rack",
  },
  {
    title: "Configuración de equipos",
    href: "/servicios/configuracion-equipos",
    description:
      "Configuramos routers, switches, puntos de acceso, cámaras, computadoras y dispositivos conectados a la red.",
    icon: "settings",
  },
  {
    title: "Soporte técnico",
    href: "/servicios/soporte-tecnico",
    description:
      "Diagnóstico, mantenimiento y solución de problemas técnicos para mantener tu operación funcionando sin interrupciones.",
    icon: "support",
  },
  {
    title: "Procesos y sistemas digitales",
    href: "/servicios/procesos-sistemas",
    description:
      "Creamos estructura digital para ordenar tareas, flujos de trabajo, información y procesos internos dentro de tu negocio.",
    icon: "systems",
  },
] as const;

const icons = {
  network: `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v6m0 6v6m0-12a3 3 0 1 0 0 6m0-6a3 3 0 0 1 0 6M5 8.5a2.5 2.5 0 1 0 0 5m14-5a2.5 2.5 0 1 1 0 5M7.2 10.2l2.4 1.2m4.8 1.2 2.4-1.2M7.2 13.8l2.4-1.2m4.8-1.2 2.4 1.2" />
    </svg>
  `,
  cable: `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h4a4 4 0 0 1 4 4v2a4 4 0 0 0 4 4h1M4 7h3m-3 10h3m10-6h3m-3 6h3M7 17h4a4 4 0 0 0 4-4v-2" />
    </svg>
  `,
  rack: `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 3h12a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 13h16M8 6h.01M8 11h.01M8 16h.01M12 6h4M12 11h4M12 16h4" />
    </svg>
  `,
  settings: `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a2.25 2.25 0 1 1-4.5 0m4.5 0a2.25 2.25 0 1 0-4.5 0M3.75 6H6m4.5 12h9.75m-9.75 0a2.25 2.25 0 1 1-4.5 0m4.5 0a2.25 2.25 0 1 0-4.5 0m-2.25 0H6m9-6h5.25M15 12a2.25 2.25 0 1 1-4.5 0m4.5 0a2.25 2.25 0 1 0-4.5 0m-6.75 0h6.75" />
    </svg>
  `,
  support: `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18 10a6 6 0 0 0-12 0v4a3 3 0 0 0 3 3h1v-6H7m10 0h-3v6h1a3 3 0 0 0 3-3v-4Z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 17v1a3 3 0 0 1-3 3h-1" />
    </svg>
  `,
  systems: `
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4H4V5Zm0 4v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 14h3m-3 3h8m-1-3h1" />
    </svg>
  `,
};

type IconName = keyof typeof icons;

const Icon = ({ name }: { name: IconName }) => {
  return icons[name];
};
---

<section id="servicios" class="relative overflow-hidden bg-[#020817] py-20 text-white sm:py-24 lg:py-28">
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(37,99,235,0.10),transparent_38%)]"></div>
    <div class="absolute left-1/2 top-0 h-px w-[70%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"></div>
  </div>

  <div class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]">
    
    <!-- Encabezado -->
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-300">
        Soluciones tecnológicas
      </p>

      <h2 class="mt-4 text-3xl font-bold tracking-[-0.03em] text-white sm:text-4xl md:text-5xl">
        Todo lo que tu negocio necesita para estar conectado, ordenado y funcionando.
      </h2>

      <p class="mt-5 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8">
        Diseñamos, instalamos y organizamos la infraestructura tecnológica que sostiene la operación diaria de tu empresa: desde la red física hasta los procesos digitales.
      </p>
    </div>

    <!-- Grid de servicios -->
    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service, index) => (
        <article class="group relative overflow-hidden rounded-[24px] border border-white/10 bg-[#061126]/70 p-6 shadow-[0_0_40px_rgba(37,99,235,0.10)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/30 hover:bg-[#071A33]/85 hover:shadow-[0_0_55px_rgba(37,99,235,0.22)]">
          
          <!-- Glow interno -->
          <div class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <div class="absolute -right-20 -top-20 h-44 w-44 rounded-full bg-blue-500/15 blur-[70px]"></div>
          </div>

          <!-- Número decorativo -->
          <div class="absolute right-5 top-5 text-5xl font-black text-white/[0.035]">
            0{index + 1}
          </div>

          <!-- Icono -->
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-2xl border border-blue-300/20 bg-blue-500/10 text-blue-300 shadow-[0_0_24px_rgba(37,99,235,0.20)] transition-all duration-300 group-hover:scale-105 group-hover:text-blue-200">
            <Fragment set:html={Icon({ name: service.icon })} />
          </div>

          <h3 class="relative z-10 mt-6 text-xl font-bold text-white">
            {service.title}
          </h3>

          <p class="relative z-10 mt-3 text-sm leading-7 text-slate-400">
            {service.description}
          </p>

          <a
  href={service.href}
  class="relative z-10 mt-6 flex items-center gap-2 text-sm font-semibold text-blue-300"
>
  Ver solución
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
    <path stroke-linecap="round" stroke-linejoin="round" d="m12 5 7 7-7 7" />
  </svg>
</a>
        </article>
      ))}
    </div>

    <!-- Banda inferior -->
    <div class="mt-12 overflow-hidden rounded-[28px] border border-blue-300/15 bg-[#061126]/65 p-6 shadow-[0_0_45px_rgba(37,99,235,0.14)] backdrop-blur-xl sm:p-8 lg:p-10">
      <div class="grid items-center gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-300">
            Diagnóstico inicial
          </p>

          <h3 class="mt-3 text-2xl font-bold tracking-[-0.03em] text-white sm:text-3xl">
            Antes de instalar, revisamos tu operación y definimos qué necesitas realmente.
          </h3>

          <p class="mt-4 text-sm leading-7 text-slate-300 sm:text-base">
            No se trata de venderte equipos por vender. Primero entendemos tu espacio, cantidad de usuarios, tipo de operación, puntos de conexión, necesidades de red y posibles problemas actuales.
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-1">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <p class="text-2xl font-bold text-white">01</p>
            <p class="mt-1 text-sm text-slate-400">Revisión del espacio</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <p class="text-2xl font-bold text-white">02</p>
            <p class="mt-1 text-sm text-slate-400">Propuesta técnica</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
            <p class="text-2xl font-bold text-white">03</p>
            <p class="mt-1 text-sm text-slate-400">Implementación ordenada</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>