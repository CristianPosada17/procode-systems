---
const values = [
  {
    title: "Orden técnico",
    description:
      "No improvisamos instalaciones. Buscamos que cada cable, equipo, conexión y proceso tenga sentido dentro de la operación.",
  },
  {
    title: "Soluciones reales",
    description:
      "Antes de recomendar equipos o instalaciones, revisamos qué necesita realmente el negocio para evitar gastos innecesarios.",
  },
  {
    title: "Visión de crecimiento",
    description:
      "Diseñamos infraestructura pensada para que el negocio pueda crecer sin que su red, equipos o procesos se vuelvan un problema.",
  },
  {
    title: "Comunicación clara",
    description:
      "Explicamos lo técnico de forma simple para que sepas qué se hará, por qué se hará y cómo ayudará a tu operación.",
  },
];

const highlights = [
  "Redes más estables",
  "Equipos mejor organizados",
  "Menos fallas operativas",
  "Procesos más claros",
];
---

<section
  id="nosotros"
  class="relative overflow-hidden bg-[#020817] py-20 text-white scroll-mt-32 sm:py-24 lg:py-28"
>
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.13),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(31,79,134,0.16),transparent_38%)]"
    >
    </div>
    <div
      class="absolute left-1/2 top-0 h-px w-[72%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
  >
    <div class="grid items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
      <!-- Visual izquierdo -->
      <div class="relative">
        <div
          class="relative overflow-hidden rounded-[32px] border border-blue-300/15 bg-[#061126]/70 p-5 shadow-[0_0_55px_rgba(37,99,235,0.16)] backdrop-blur-xl sm:p-6 lg:p-8"
        >
          <div
            class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.22),transparent_42%)]"
          >
          </div>

          <!-- Header visual -->
          <div
            class="relative flex items-center justify-between border-b border-white/10 pb-5"
          >
            <div class="flex items-center gap-3">
              <img
                src="/Logo/Logofondoazul.webp"
                alt="ProCode Systems"
                class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
              />

              <div>
                <p class="text-lg font-bold text-white">ProCode Systems</p>
                <p class="text-sm text-slate-400">
                  Infraestructura tecnológica
                </p>
              </div>
            </div>

            <span
              class="hidden rounded-full border border-blue-300/20 bg-blue-500/10 px-3 py-1.5 text-xs font-semibold text-blue-300 sm:inline-flex"
            >
              IT Solutions
            </span>
          </div>

          <!-- Rack / Network visual -->
          <div class="relative mt-6 grid gap-5 sm:grid-cols-[0.8fr_1.2fr]">
            <!-- Rack -->
            <div
              class="rounded-[24px] border border-white/10 bg-[#020817]/60 p-4"
            >
              <div class="mb-4 flex items-center justify-between">
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-300"
                >
                  Rack
                </p>
                <span
                  class="h-2.5 w-2.5 rounded-full bg-green-400 shadow-[0_0_14px_rgba(74,222,128,0.9)]"
                ></span>
              </div>

              <div class="space-y-3">
                <div
                  class="h-8 rounded-xl border border-blue-300/15 bg-blue-500/10"
                >
                </div>
                <div
                  class="h-8 rounded-xl border border-blue-300/15 bg-blue-500/10"
                >
                </div>
                <div
                  class="h-8 rounded-xl border border-blue-300/15 bg-blue-500/10"
                >
                </div>
                <div
                  class="h-8 rounded-xl border border-blue-300/15 bg-blue-500/10"
                >
                </div>
                <div
                  class="h-8 rounded-xl border border-blue-300/15 bg-blue-500/10"
                >
                </div>
              </div>
            </div>

            <!-- Panel -->
            <div
              class="rounded-[24px] border border-white/10 bg-[#020817]/60 p-4"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-300"
              >
                Estado operativo
              </p>

              <div class="mt-5 grid gap-3">
                <div
                  class="rounded-2xl border border-white/10 bg-white/[0.035] p-4"
                >
                  <div class="flex items-center justify-between">
                    <p class="text-sm font-bold text-white">Red principal</p>
                    <span class="text-xs font-semibold text-green-300"
                      >Estable</span
                    >
                  </div>
                  <div class="mt-3 h-2 rounded-full bg-white/10">
                    <div
                      class="h-2 w-[92%] rounded-full bg-blue-400 shadow-[0_0_18px_rgba(96,165,250,0.7)]"
                    >
                    </div>
                  </div>
                </div>

                <div
                  class="rounded-2xl border border-white/10 bg-white/[0.035] p-4"
                >
                  <div class="flex items-center justify-between">
                    <p class="text-sm font-bold text-white">Cableado</p>
                    <span class="text-xs font-semibold text-blue-300"
                      >Ordenado</span
                    >
                  </div>
                  <div class="mt-3 h-2 rounded-full bg-white/10">
                    <div
                      class="h-2 w-[84%] rounded-full bg-blue-500 shadow-[0_0_18px_rgba(59,130,246,0.7)]"
                    >
                    </div>
                  </div>
                </div>

                <div
                  class="rounded-2xl border border-white/10 bg-white/[0.035] p-4"
                >
                  <div class="flex items-center justify-between">
                    <p class="text-sm font-bold text-white">Procesos</p>
                    <span class="text-xs font-semibold text-blue-300"
                      >Optimizados</span
                    >
                  </div>
                  <div class="mt-3 h-2 rounded-full bg-white/10">
                    <div
                      class="h-2 w-[76%] rounded-full bg-blue-600 shadow-[0_0_18px_rgba(37,99,235,0.7)]"
                    >
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Mini cards -->
          <div class="relative mt-5 grid gap-3 sm:grid-cols-2">
            {
              highlights.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
                  <div class="flex items-center gap-3">
                    <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl border border-blue-300/20 bg-blue-500/10 text-blue-300">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="m5 13 4 4L19 7"
                        />
                      </svg>
                    </span>
                    <p class="text-sm font-semibold text-slate-200">{item}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Texto derecho -->
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-300"
        >
          Sobre ProCode Systems
        </p>

        <h2
          class="mt-4 max-w-3xl text-3xl font-bold tracking-[-0.03em] text-white sm:text-4xl md:text-5xl"
        >
          Construimos la base tecnológica que tu negocio necesita para operar
          con orden.
        </h2>

        <p
          class="mt-6 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
        >
          ProCode Systems nace para ayudar a negocios, oficinas y empresas que
          necesitan una infraestructura tecnológica más clara, estable y
          profesional. Nuestro enfoque combina redes, cableado estructurado,
          organización técnica, soporte y procesos digitales.
        </p>

        <p
          class="mt-4 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
        >
          No se trata solo de conectar cables o instalar equipos. Se trata de
          entender cómo trabaja tu negocio y crear una estructura que reduzca
          fallas, mejore la operación y facilite el crecimiento.
        </p>

        <!-- Valores -->
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {
            values.map((value) => (
              <article class="rounded-[22px] border border-white/10 bg-[#061126]/65 p-5 shadow-[0_0_35px_rgba(37,99,235,0.10)] backdrop-blur-xl transition-all duration-300 hover:border-blue-300/30 hover:bg-[#071A33]/80">
                <h3 class="text-lg font-bold text-white">{value.title}</h3>

                <p class="mt-3 text-sm leading-7 text-slate-400">
                  {value.description}
                </p>
              </article>
            ))
          }
        </div>

        <!-- CTA -->
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="#contacto"
            class="group inline-flex items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-6 py-3.5 text-sm font-bold text-white shadow-[0_0_30px_rgba(37,99,235,0.38)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400"
          >
            Solicitar diagnóstico
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m12 5 7 7-7 7"></path>
            </svg>
          </a>

          <a
            href="#servicios"
            class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.03] px-6 py-3.5 text-sm font-semibold text-white transition-all duration-300 hover:border-blue-300/30 hover:bg-blue-500/10"
          >
            Ver soluciones
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
