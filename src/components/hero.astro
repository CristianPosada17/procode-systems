---
const features = [
  "Redes profesionales",
  "Racks y cableado estructurado",
  "Procesos digitales",
  "Soporte técnico",
];

const stats = [
  { value: "99.9%", label: "Conectividad" },
  { value: "24/7", label: "Operación estable" },
  { value: "100%", label: "Estructura clara" },
];
---

<section
  id="inicio"
  class="relative scroll-mt-32 overflow-hidden bg-[#020817] pt-32 text-white sm:pt-36 lg:min-h-screen lg:pt-40"
>
  <!-- Fondo principal -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.22),transparent_34%),radial-gradient(circle_at_top_left,rgba(31,79,134,0.18),transparent_32%),linear-gradient(180deg,#020817_0%,#030B1A_45%,#020817_100%)]"
    >
    </div>
    <div
      class="absolute right-[-120px] top-20 h-[360px] w-[360px] rounded-full bg-blue-600/10 blur-[100px] sm:h-[520px] sm:w-[520px] lg:right-0"
    >
    </div>
    <div
      class="absolute left-[-120px] top-64 h-[280px] w-[280px] rounded-full bg-[#1F4F86]/20 blur-[90px] sm:left-10 sm:h-[320px] sm:w-[320px]"
    >
    </div>
  </div>

  <!-- Patrón sutil -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.12] sm:opacity-[0.16] lg:opacity-[0.18]"
  >
    <div
      class="absolute right-[-220px] top-28 h-[520px] w-[620px] bg-[linear-gradient(90deg,rgba(96,165,250,0.16)_1px,transparent_1px),linear-gradient(180deg,rgba(96,165,250,0.12)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(circle_at_center,black,transparent_70%)] sm:right-[-80px] lg:right-0 lg:h-[620px] lg:w-[720px] lg:bg-[size:72px_72px]"
    >
    </div>
  </div>

  <div
    class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
  >
    <div
      class="grid items-center gap-14 pb-20 sm:pb-24 lg:min-h-[calc(100vh-160px)] lg:grid-cols-[1.02fr_0.98fr] lg:gap-10 lg:pb-16"
    >
      <!-- Contenido izquierdo -->
      <div class="mx-auto max-w-3xl text-center lg:mx-0 lg:text-left">
        <div
          class="mb-6 inline-flex max-w-full items-center gap-3 rounded-full border border-blue-400/20 bg-blue-500/5 px-4 py-2 shadow-[0_0_24px_rgba(37,99,235,0.12)] backdrop-blur-xl"
        >
          <span
            class="h-2 w-2 shrink-0 rounded-full bg-blue-400 shadow-[0_0_14px_rgba(96,165,250,1)]"
          ></span>
          <span
            class="truncate text-[10px] font-semibold uppercase tracking-[0.22em] text-blue-300 sm:text-xs sm:tracking-[0.32em]"
          >
            Tecnología. Redes. Sistemas. Procesos.
          </span>
        </div>

        <h1
          class="mx-auto max-w-4xl text-4xl font-bold leading-[1.05] tracking-[-0.04em] text-white sm:text-5xl md:text-6xl lg:mx-0 lg:text-7xl xl:text-[82px]"
        >
          Infraestructura
          <span class="block">tecnológica.</span>
          <span
            class="block bg-gradient-to-r from-blue-400 via-blue-500 to-blue-300 bg-clip-text text-transparent"
          >
            Redes profesionales
          </span>
          <span class="block">para tu negocio.</span>
        </h1>

        <p
          class="mx-auto mt-6 max-w-2xl text-sm leading-7 text-slate-300 sm:text-base sm:leading-8 md:text-lg lg:mx-0"
        >
          En ProCode Systems ayudamos a empresas, oficinas y negocios a
          construir una base tecnológica sólida: redes de internet, cableado
          estructurado, racks, organización de equipos, soporte técnico y
          procesos digitales que mantienen todo conectado, ordenado y
          funcionando.
        </p>

        <div
          class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center lg:justify-start"
        >
          <a
            href="#contacto"
            class="group inline-flex items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-7 py-4 text-sm font-bold text-white shadow-[0_0_34px_rgba(37,99,235,0.40)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400 hover:shadow-[0_0_48px_rgba(59,130,246,0.62)]"
          >
            Solicitar diagnóstico
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m12 5 7 7-7 7"></path>
            </svg>
          </a>

          <a
            href="#servicios"
            class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.03] px-7 py-4 text-sm font-semibold text-white shadow-inner shadow-white/5 backdrop-blur-xl transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300/30 hover:bg-blue-500/10"
          >
            Ver soluciones
          </a>
        </div>

        <div
          class="mx-auto mt-9 grid max-w-md grid-cols-1 gap-3 sm:max-w-none sm:grid-cols-2 md:flex md:flex-wrap md:items-center md:justify-center md:gap-x-7 md:gap-y-4 lg:justify-start"
        >
          {
            features.map((feature) => (
              <div class="flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/[0.025] px-4 py-3 text-sm text-slate-300 backdrop-blur-xl md:border-0 md:bg-transparent md:px-0 md:py-0 md:backdrop-blur-0">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-blue-400/20 bg-blue-500/10 text-blue-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-3.5 w-3.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m5 13 4 4L19 7"
                    />
                  </svg>
                </span>
                {feature}
              </div>
            ))
          }
        </div>
      </div>

      <!-- Visual derecho responsive -->
      <div class="relative mx-auto w-full max-w-2xl lg:mx-0 lg:max-w-none">
        <!-- Contenedor visual para mobile/tablet -->
        <div
          class="relative overflow-hidden rounded-[28px] border border-blue-300/15 bg-[#061126]/55 p-4 shadow-[0_0_55px_rgba(37,99,235,0.18)] backdrop-blur-xl sm:p-6 lg:hidden"
        >
          <div
            class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.20),transparent_38%)]"
          >
          </div>

          <div
            class="relative flex items-center justify-between gap-4 border-b border-white/10 pb-4"
          >
            <div class="flex items-center gap-3">
              <img
                src="/Logo/ProCodeLogo.svg"
                alt="ProCode Systems"
                class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
              />
              <div>
                <p class="text-sm font-bold text-white sm:text-base">
                  ProCode Systems
                </p>
                <p class="text-xs text-slate-400">Panel de infraestructura</p>
              </div>
            </div>

            <div
              class="rounded-full border border-blue-300/20 bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-200"
            >
              Activo
            </div>
          </div>

          <div class="relative mt-5 grid grid-cols-3 gap-3">
            {
              stats.map((stat) => (
                <div class="rounded-xl border border-white/10 bg-white/[0.035] p-3">
                  <p class="text-base font-bold text-white sm:text-lg">
                    {stat.value}
                  </p>
                  <p class="mt-1 text-[10px] leading-4 text-slate-400 sm:text-[11px]">
                    {stat.label}
                  </p>
                </div>
              ))
            }
          </div>

          <div
            class="relative mt-5 rounded-2xl border border-white/10 bg-[#020817]/60 p-4"
          >
            <div class="mb-4 flex items-center justify-between">
              <p
                class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-300"
              >
                Estado de red
              </p>
              <span class="text-xs text-slate-400">Estable</span>
            </div>

            <svg viewBox="0 0 320 100" class="h-32 w-full overflow-visible">
              <path
                d="M0 72 C35 30, 58 84, 90 52 S145 38, 175 62 S230 78, 260 35 S300 26, 320 18"
                fill="none"
                stroke="rgba(96,165,250,0.95)"
                stroke-width="3"
                stroke-linecap="round"></path>
              <path
                d="M0 72 C35 30, 58 84, 90 52 S145 38, 175 62 S230 78, 260 35 S300 26, 320 18"
                fill="none"
                stroke="rgba(37,99,235,0.35)"
                stroke-width="10"
                stroke-linecap="round"
                class="blur-sm"></path>
            </svg>
          </div>

          <div
            class="relative mt-5 rounded-2xl border border-white/10 bg-[#020817]/50 p-4"
          >
            <div class="mb-3 flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-green-400/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-blue-400/80"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-cyan-400/80"></span>
              <span class="ml-auto text-xs font-semibold text-blue-300"
                >NETWORK</span
              >
            </div>

            <pre
              class="overflow-hidden text-[11px] leading-5 text-slate-300 sm:text-xs sm:leading-6"><code><span class="text-blue-300">system</span>.connect() &#123;
  <span class="text-blue-400">rack</span>: organized;
  <span class="text-blue-400">network</span>: stable;
  <span class="text-blue-400">process</span>: optimized;

  <span class="text-blue-300">status</span>: online;
&#125;</code></pre>
          </div>
        </div>

        <!-- Composición desktop -->
        <div class="relative hidden min-h-[620px] lg:block">
          <!-- Líneas de conexión -->
          <div class="pointer-events-none absolute inset-0">
            <div
              class="absolute right-8 top-20 h-px w-[440px] bg-gradient-to-r from-transparent via-blue-400/40 to-transparent"
            >
            </div>
            <div
              class="absolute right-20 top-20 h-[330px] w-px bg-gradient-to-b from-blue-400/50 via-blue-500/20 to-transparent"
            >
            </div>
            <div
              class="absolute bottom-32 right-10 h-px w-[420px] bg-gradient-to-r from-transparent via-blue-500/35 to-transparent"
            >
            </div>
          </div>

          <!-- Panel técnico -->
          <div
            class="absolute left-6 top-4 w-[360px] rotate-[-4deg] rounded-2xl border border-blue-300/15 bg-[#061126]/80 p-5 shadow-[0_0_50px_rgba(37,99,235,0.22)] backdrop-blur-xl"
          >
            <div class="mb-4 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-green-400/80"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-blue-400/80"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-cyan-400/80"></span>
              </div>
              <span class="text-xs font-semibold text-blue-300">NETWORK</span>
            </div>

            <pre
              class="overflow-hidden text-[12px] leading-6 text-slate-300"><code><span class="text-blue-300">system</span>.connect() &#123;
  <span class="text-blue-400">rack</span>: organized;
  <span class="text-blue-400">cabling</span>: structured;
  <span class="text-blue-400">network</span>: stable;
  <span class="text-blue-400">process</span>: optimized;

  <span class="text-blue-300">status</span>: online;
&#125;</code></pre>
          </div>

          <!-- Dashboard superior -->
          <div
            class="absolute right-0 top-28 w-[400px] rounded-2xl border border-blue-300/15 bg-[#071A33]/80 p-5 shadow-[0_0_55px_rgba(37,99,235,0.24)] backdrop-blur-xl"
          >
            <div class="mb-5 flex items-center justify-between">
              <div>
                <p
                  class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-300"
                >
                  Panel de operación
                </p>
                <h3 class="mt-2 text-lg font-bold text-white">
                  Infraestructura activa
                </h3>
              </div>

              <div
                class="rounded-full border border-blue-300/20 bg-blue-500/10 px-3 py-1 text-xs font-semibold text-blue-200"
              >
                Online
              </div>
            </div>

            <div class="grid grid-cols-3 gap-3">
              {
                stats.map((stat) => (
                  <div class="rounded-xl border border-white/10 bg-white/[0.035] p-3">
                    <p class="text-lg font-bold text-white">{stat.value}</p>
                    <p class="mt-1 text-[11px] text-slate-400">{stat.label}</p>
                  </div>
                ))
              }
            </div>

            <div
              class="mt-5 h-28 rounded-xl border border-white/10 bg-[#020817]/55 p-4"
            >
              <svg viewBox="0 0 320 100" class="h-full w-full overflow-visible">
                <path
                  d="M0 72 C35 30, 58 84, 90 52 S145 38, 175 62 S230 78, 260 35 S300 26, 320 18"
                  fill="none"
                  stroke="rgba(96,165,250,0.95)"
                  stroke-width="3"
                  stroke-linecap="round"></path>
                <path
                  d="M0 72 C35 30, 58 84, 90 52 S145 38, 175 62 S230 78, 260 35 S300 26, 320 18"
                  fill="none"
                  stroke="rgba(37,99,235,0.35)"
                  stroke-width="10"
                  stroke-linecap="round"
                  class="blur-sm"></path>
              </svg>
            </div>
          </div>

          <!-- Card de soluciones -->
          <div
            class="absolute bottom-24 left-0 w-[360px] rounded-2xl border border-blue-300/15 bg-[#061126]/75 p-5 shadow-[0_0_50px_rgba(37,99,235,0.20)] backdrop-blur-xl"
          >
            <div
              class="mb-4 flex items-center justify-between border-b border-white/10 pb-3"
            >
              <span class="text-xs font-bold text-blue-300">IT SYSTEMS</span>
              <div class="flex gap-1.5">
                <span class="h-1.5 w-8 rounded-full bg-blue-400/60"></span>
                <span class="h-1.5 w-5 rounded-full bg-blue-400/25"></span>
                <span class="h-1.5 w-5 rounded-full bg-blue-400/25"></span>
              </div>
            </div>

            <div class="flex items-center gap-4">
              <img
                src="/Logo/ProCodeLogo.svg"
                alt="ProCode Systems"
                class="h-14 w-14 rounded-full object-contain shadow-[0_0_20px_rgba(59,130,246,0.35)]"
              />

              <div>
                <h3 class="text-lg font-bold text-white">ProCode Systems</h3>
                <p class="mt-1 text-sm leading-5 text-slate-400">
                  Redes, racks, procesos y sistemas listos para operar con orden
                  y estabilidad.
                </p>
              </div>
            </div>

            <div
              class="mt-5 inline-flex rounded-lg bg-blue-500/10 px-3 py-2 text-xs font-semibold text-blue-300"
            >
              Ver soluciones
            </div>
          </div>

          <!-- Logo central -->
          <div
            class="absolute left-1/2 top-[270px] flex h-36 w-36 -translate-x-1/2 items-center justify-center rounded-full border border-blue-300/25 bg-[#1F4F86] shadow-[0_0_70px_rgba(37,99,235,0.58)]"
          >
            <img
              src="/Logo/ProCodeLogo.svg"
              alt="ProCode Systems"
              class="h-36 w-36 rounded-full object-contain"
            />
          </div>

          <!-- Nodos decorativos -->
          <span
            class="absolute right-40 top-16 h-2.5 w-2.5 rounded-full bg-blue-300 shadow-[0_0_18px_rgba(96,165,250,1)]"
          ></span>
          <span
            class="absolute right-16 top-96 h-2 w-2 rounded-full bg-blue-400 shadow-[0_0_18px_rgba(96,165,250,1)]"
          ></span>
          <span
            class="absolute bottom-20 left-80 h-2 w-2 rounded-full bg-blue-500 shadow-[0_0_18px_rgba(59,130,246,1)]"
          ></span>
        </div>
      </div>
    </div>
  </div>
</section>
