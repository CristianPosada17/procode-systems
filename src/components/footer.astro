---
const companyLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "Servicios", href: "#servicios" },
  { label: "Proceso", href: "#proceso" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Contacto", href: "#contacto" },
];

const serviceLinks = [
  { label: "Redes empresariales", href: "#servicios" },
  { label: "Cableado estructurado", href: "#servicios" },
  { label: "Racks y organización", href: "#servicios" },
  { label: "Soporte técnico", href: "#servicios" },
  { label: "Procesos digitales", href: "#servicios" },
];

const resourceLinks = [
  { label: "Recursos técnicos", href: "#blog" },
  { label: "Diagnóstico inicial", href: "#contacto" },
  { label: "Soluciones en acción", href: "#portafolio" },
  { label: "Metodología", href: "#proceso" },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-[#020817] text-white">
  <!-- Fondo decorativo -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(37,99,235,0.12),transparent_34%),radial-gradient(circle_at_bottom_right,rgba(31,79,134,0.14),transparent_38%)]"
    >
    </div>
    <div
      class="absolute left-1/2 top-0 h-px w-[72%] -translate-x-1/2 bg-gradient-to-r from-transparent via-blue-400/35 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative mx-auto w-full max-w-[1480px] px-4 pb-8 pt-16 sm:px-6 sm:pt-20 lg:px-10 lg:pt-24 2xl:max-w-[1600px]"
  >
    <!-- Footer principal -->
    <div
      class="overflow-hidden rounded-[32px] border border-blue-300/15 bg-[#061126]/70 shadow-[0_0_55px_rgba(37,99,235,0.14)] backdrop-blur-xl"
    >
      <div
        class="grid gap-10 p-6 sm:p-8 lg:grid-cols-[1.2fr_0.8fr_0.8fr_0.8fr] lg:p-10"
      >
        <!-- Marca -->
        <div>
          <a href="#inicio" class="inline-flex items-center gap-3">
            <img
              src="/Logo/ProCodeLogo.svg"
              alt="ProCode Systems"
              class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
            />

            <div class="leading-none">
              <p class="text-[22px] font-bold tracking-tight text-white">
                ProCode
              </p>
              <p
                class="mt-1 text-[10px] font-semibold uppercase tracking-[0.42em] text-blue-100/90"
              >
                Systems
              </p>
            </div>
          </a>

          <p class="mt-6 max-w-md text-sm leading-7 text-slate-400">
            Infraestructura tecnológica para negocios que necesitan redes
            estables, cableado estructurado, racks organizados, soporte técnico
            y procesos digitales más claros.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="https://wa.me/526142414255"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/[0.035] text-blue-300 transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300/30 hover:bg-blue-500/10 hover:text-blue-200"
              aria-label="WhatsApp"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M20.52 3.48A11.82 11.82 0 0 0 12.09 0C5.52 0 .18 5.34.18 11.91c0 2.1.55 4.16 1.6 5.97L.08 24l6.27-1.64a11.9 11.9 0 0 0 5.74 1.46h.01c6.57 0 11.91-5.34 11.91-11.91 0-3.18-1.24-6.17-3.49-8.43ZM12.1 21.8h-.01a9.9 9.9 0 0 1-5.05-1.38l-.36-.21-3.72.97.99-3.63-.23-.37a9.87 9.87 0 0 1-1.51-5.27c0-5.45 4.43-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.89 9.88Zm5.42-7.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.39-1.47-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.88 1.21 3.08c.15.2 2.09 3.19 5.06 4.47.71.31 1.26.49 1.69.63.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2.01-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35Z"
                ></path>
              </svg>
            </a>

            <a
              href="mailto:info@procodedev.com"
              class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 bg-white/[0.035] text-blue-300 transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300/30 hover:bg-blue-500/10 hover:text-blue-200"
              aria-label="Correo"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5A2.25 2.25 0 0 1 19.5 19.5h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0-9.75 6.75L2.25 6.75"
                ></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Empresa -->
        <div>
          <h3
            class="text-sm font-bold uppercase tracking-[0.24em] text-blue-300"
          >
            Empresa
          </h3>

          <ul class="mt-5 space-y-3">
            {
              companyLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-400 transition-colors duration-300 hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Servicios -->
        <div>
          <h3
            class="text-sm font-bold uppercase tracking-[0.24em] text-blue-300"
          >
            Servicios
          </h3>

          <ul class="mt-5 space-y-3">
            {
              serviceLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-400 transition-colors duration-300 hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Recursos -->
        <div>
          <h3
            class="text-sm font-bold uppercase tracking-[0.24em] text-blue-300"
          >
            Recursos
          </h3>

          <ul class="mt-5 space-y-3">
            {
              resourceLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-400 transition-colors duration-300 hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Línea inferior -->
      <div class="border-t border-white/10 px-6 py-5 sm:px-8 lg:px-10">
        <div
          class="flex flex-col gap-4 text-sm text-slate-500 md:flex-row md:items-center md:justify-between"
        >
          <p>
            © {currentYear} ProCode Systems. Todos los derechos reservados.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="#"
              class="transition-colors duration-300 hover:text-slate-300"
            >
              Privacidad
            </a>
            <a
              href="#"
              class="transition-colors duration-300 hover:text-slate-300"
            >
              Términos
            </a>
            <span> Durango, México </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
