---
import Layout from "../../layouts/layout.astro";
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import { posts, type BlogPost } from "../../data/blog";

export async function getStaticPaths() {
  return posts.map((post: BlogPost) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: BlogPost;
};

const { post } = Astro.props as Props;
---

<Layout title={`${post.title} | ProCode Systems`} description={post.excerpt}>
  <Header />

  <main class="bg-[#020817] text-white">
    <!-- Hero del artículo -->
    <section
      class="relative overflow-hidden pb-20 pt-36 sm:pb-24 sm:pt-40 lg:pb-28 lg:pt-44"
    >
      <div class="pointer-events-none absolute inset-0">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.22),transparent_34%),radial-gradient(circle_at_top_left,rgba(31,79,134,0.18),transparent_32%),linear-gradient(180deg,#020817_0%,#030B1A_45%,#020817_100%)]"
        >
        </div>
        <div
          class="absolute right-[-120px] top-20 h-[420px] w-[420px] rounded-full bg-blue-600/10 blur-[110px]"
        >
        </div>
      </div>

      <div
        class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
      >
        <div class="mx-auto max-w-4xl text-center">
          <a
            href="/#blog"
            class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-blue-300 transition-colors duration-300 hover:text-blue-200"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m12 19-7-7 7-7"></path>
            </svg>
            Volver a recursos
          </a>

          <div
            class="mb-6 inline-flex items-center gap-3 rounded-full border border-blue-400/20 bg-blue-500/5 px-4 py-2 shadow-[0_0_24px_rgba(37,99,235,0.12)] backdrop-blur-xl"
          >
            <span
              class="h-2 w-2 rounded-full bg-blue-400 shadow-[0_0_14px_rgba(96,165,250,1)]"
            ></span>
            <span
              class="text-[10px] font-semibold uppercase tracking-[0.22em] text-blue-300 sm:text-xs sm:tracking-[0.32em]"
            >
              {post.category} · {post.readTime} de lectura
            </span>
          </div>

          <h1
            class="text-4xl font-bold leading-[1.05] tracking-[-0.04em] text-white sm:text-5xl md:text-6xl"
          >
            {post.title}
          </h1>

          <p
            class="mx-auto mt-6 max-w-3xl text-sm leading-7 text-slate-300 sm:text-base sm:leading-8 md:text-lg"
          >
            {post.excerpt}
          </p>
        </div>
      </div>
    </section>

    <!-- Contenido del artículo -->
    <section class="relative overflow-hidden pb-20 sm:pb-24 lg:pb-28">
      <div
        class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
      >
        <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[0.75fr_1.25fr]">
          <!-- Sidebar -->
          <aside class="lg:sticky lg:top-32 lg:self-start">
            <div
              class="rounded-[28px] border border-blue-300/15 bg-[#061126]/70 p-6 shadow-[0_0_45px_rgba(37,99,235,0.14)] backdrop-blur-xl"
            >
              <div class="flex items-center gap-3">
                <img
                  src="/Logo/Logofondoazul.webp"
                  alt="ProCode Systems"
                  class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
                />

                <div>
                  <p class="text-lg font-bold text-white">ProCode Systems</p>
                  <p class="text-sm text-slate-400">Recursos técnicos</p>
                </div>
              </div>

              <div
                class="mt-6 rounded-2xl border border-white/10 bg-[#020817]/60 p-5"
              >
                <p
                  class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-300"
                >
                  Categoría
                </p>
                <p class="mt-3 text-xl font-bold text-white">{post.category}</p>
              </div>

              <div
                class="mt-4 rounded-2xl border border-white/10 bg-[#020817]/60 p-5"
              >
                <p
                  class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-300"
                >
                  Tiempo de lectura
                </p>
                <p class="mt-3 text-xl font-bold text-white">{post.readTime}</p>
              </div>

              <a
                href="/#contacto"
                class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-5 py-3.5 text-sm font-bold text-white shadow-[0_0_30px_rgba(37,99,235,0.38)] transition-all duration-300 hover:from-blue-500 hover:to-blue-400"
              >
                Solicitar diagnóstico
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 12h14"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m12 5 7 7-7 7"></path>
                </svg>
              </a>
            </div>
          </aside>

          <!-- Artículo -->
          <article
            class="rounded-[32px] border border-white/10 bg-[#061126]/70 p-6 shadow-[0_0_55px_rgba(37,99,235,0.14)] backdrop-blur-xl sm:p-8 lg:p-10"
          >
            <p class="text-base leading-8 text-slate-300 sm:text-lg">
              {post.intro}
            </p>

            <div class="mt-10 space-y-8">
              {
                post.sections.map((section) => (
                  <section>
                    <h2 class="text-2xl font-bold tracking-[-0.03em] text-white sm:text-3xl">
                      {section.title}
                    </h2>

                    <p class="mt-4 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8">
                      {section.content}
                    </p>
                  </section>
                ))
              }
            </div>

            <div
              class="mt-10 rounded-[24px] border border-blue-300/15 bg-[#020817]/60 p-6"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-300"
              >
                Conclusión
              </p>

              <p
                class="mt-4 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
              >
                {post.conclusion}
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
