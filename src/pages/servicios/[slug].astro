---
import Layout from "../../layouts/layout.astro";
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import { services } from "../../data/services";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout
  title={`${service.title} | ProCode Systems`}
  description={service.description}
>
  <Header />

  <main class="bg-[#020817] text-white">
    <!-- Hero del servicio -->
    <section
      class="relative overflow-hidden pt-36 pb-20 scroll-mt-32 sm:pt-40 sm:pb-24 lg:pt-44 lg:pb-28"
    >
      <div class="pointer-events-none absolute inset-0">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.22),transparent_34%),radial-gradient(circle_at_top_left,rgba(31,79,134,0.18),transparent_32%),linear-gradient(180deg,#020817_0%,#030B1A_45%,#020817_100%)]"
        >
        </div>
        <div
          class="absolute right-[-120px] top-20 h-[420px] w-[420px] rounded-full bg-blue-600/10 blur-[110px]"
        >
        </div>
      </div>

      <div
        class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
      >
        <div class="grid items-center gap-12 lg:grid-cols-[1fr_0.9fr]">
          <div>
            <a
              href="/#servicios"
              class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-blue-300 transition-colors duration-300 hover:text-blue-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19 12H5"></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m12 19-7-7 7-7"></path>
              </svg>
              Volver a servicios
            </a>

            <div
              class="mb-6 inline-flex items-center gap-3 rounded-full border border-blue-400/20 bg-blue-500/5 px-4 py-2 shadow-[0_0_24px_rgba(37,99,235,0.12)] backdrop-blur-xl"
            >
              <span
                class="h-2 w-2 rounded-full bg-blue-400 shadow-[0_0_14px_rgba(96,165,250,1)]"
              ></span>
              <span
                class="text-[10px] font-semibold uppercase tracking-[0.22em] text-blue-300 sm:text-xs sm:tracking-[0.32em]"
              >
                {service.eyebrow}
              </span>
            </div>

            <h1
              class="max-w-4xl text-4xl font-bold leading-[1.05] tracking-[-0.04em] text-white sm:text-5xl md:text-6xl lg:text-7xl"
            >
              {service.title}
            </h1>

            <p
              class="mt-6 max-w-3xl text-sm leading-7 text-slate-300 sm:text-base sm:leading-8 md:text-lg"
            >
              {service.description}
            </p>

            <div class="mt-8 flex flex-col gap-4 sm:flex-row">
              <a
                href="#contacto-servicio"
                class="group inline-flex items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-7 py-4 text-sm font-bold text-white shadow-[0_0_34px_rgba(37,99,235,0.40)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400"
              >
                Solicitar diagnóstico
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 12h14"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m12 5 7 7-7 7"></path>
                </svg>
              </a>

              <a
                href="https://wa.me/526182302938"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.03] px-7 py-4 text-sm font-semibold text-white shadow-inner shadow-white/5 backdrop-blur-xl transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300/30 hover:bg-blue-500/10"
              >
                Hablar por WhatsApp
              </a>
            </div>
          </div>

          <!-- Visual -->
          <div
            class="relative overflow-hidden rounded-[32px] border border-blue-300/15 bg-[#061126]/70 p-6 shadow-[0_0_55px_rgba(37,99,235,0.16)] backdrop-blur-xl lg:p-8"
          >
            <div
              class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(37,99,235,0.20),transparent_42%)]"
            >
            </div>

            <div
              class="relative flex items-center gap-3 border-b border-white/10 pb-5"
            >
              <img
                src="/Logo/Logofondoazul.webp"
                alt="ProCode Systems"
                class="h-14 w-14 rounded-full object-contain shadow-[0_0_24px_rgba(59,130,246,0.35)]"
              />

              <div>
                <p class="text-lg font-bold text-white">ProCode Systems</p>
                <p class="text-sm text-slate-400">Solución técnica</p>
              </div>
            </div>

            <div
              class="relative mt-6 rounded-[24px] border border-white/10 bg-[#020817]/60 p-5"
            >
              <p
                class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-300"
              >
                Estado de solución
              </p>

              <div class="mt-5 space-y-4">
                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <span class="text-sm font-semibold text-slate-300"
                      >Diagnóstico</span
                    >
                    <span class="text-xs text-blue-300">100%</span>
                  </div>
                  <div class="h-2 rounded-full bg-white/10">
                    <div
                      class="h-2 w-full rounded-full bg-blue-400 shadow-[0_0_18px_rgba(96,165,250,0.7)]"
                    >
                    </div>
                  </div>
                </div>

                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <span class="text-sm font-semibold text-slate-300"
                      >Planeación</span
                    >
                    <span class="text-xs text-blue-300">90%</span>
                  </div>
                  <div class="h-2 rounded-full bg-white/10">
                    <div
                      class="h-2 w-[90%] rounded-full bg-blue-500 shadow-[0_0_18px_rgba(59,130,246,0.7)]"
                    >
                    </div>
                  </div>
                </div>

                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <span class="text-sm font-semibold text-slate-300"
                      >Implementación</span
                    >
                    <span class="text-xs text-blue-300">85%</span>
                  </div>
                  <div class="h-2 rounded-full bg-white/10">
                    <div
                      class="h-2 w-[85%] rounded-full bg-blue-600 shadow-[0_0_18px_rgba(37,99,235,0.7)]"
                    >
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="relative mt-5 grid gap-3 sm:grid-cols-2">
              {
                service.benefits.slice(0, 4).map((benefit) => (
                  <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4">
                    <div class="flex items-center gap-3">
                      <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl border border-blue-300/20 bg-blue-500/10 text-blue-300">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          class="h-4 w-4"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="m5 13 4 4L19 7"
                          />
                        </svg>
                      </span>
                      <p class="text-sm font-semibold text-slate-200">
                        {benefit}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problema y solución -->
    <section class="relative overflow-hidden py-20 sm:py-24 lg:py-28">
      <div
        class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
      >
        <div class="grid gap-6 lg:grid-cols-2">
          <article
            class="rounded-[28px] border border-white/10 bg-[#061126]/70 p-6 shadow-[0_0_40px_rgba(37,99,235,0.10)] backdrop-blur-xl sm:p-8"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-300"
            >
              El problema
            </p>
            <h2
              class="mt-4 text-2xl font-bold tracking-[-0.03em] text-white sm:text-3xl"
            >
              Cuando la tecnología no tiene estructura, la operación se vuelve
              lenta.
            </h2>
            <p
              class="mt-5 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
            >
              {service.problem}
            </p>
          </article>

          <article
            class="rounded-[28px] border border-blue-300/15 bg-[#071A33]/75 p-6 shadow-[0_0_45px_rgba(37,99,235,0.16)] backdrop-blur-xl sm:p-8"
          >
            <p
              class="text-xs font-semibold uppercase tracking-[0.28em] text-blue-300"
            >
              Nuestra solución
            </p>
            <h2
              class="mt-4 text-2xl font-bold tracking-[-0.03em] text-white sm:text-3xl"
            >
              Primero entendemos tu operación, después diseñamos la solución.
            </h2>
            <p
              class="mt-5 text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
            >
              {service.solution}
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- Qué incluye -->
    <section class="relative overflow-hidden py-20 sm:py-24 lg:py-28">
      <div
        class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
      >
        <div class="mx-auto max-w-3xl text-center">
          <p
            class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-300"
          >
            Qué incluye
          </p>

          <h2
            class="mt-4 text-3xl font-bold tracking-[-0.03em] text-white sm:text-4xl md:text-5xl"
          >
            Una solución pensada para resolver, ordenar y mejorar tu operación.
          </h2>
        </div>

        <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            service.includes.map((item, index) => (
              <article class="rounded-[24px] border border-white/10 bg-[#061126]/70 p-6 shadow-[0_0_40px_rgba(37,99,235,0.10)] backdrop-blur-xl transition-all duration-300 hover:-translate-y-1 hover:border-blue-300/30 hover:bg-[#071A33]/85">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-blue-300/20 bg-blue-500/10 text-sm font-black text-blue-300">
                  0{index + 1}
                </div>

                <h3 class="mt-5 text-lg font-bold text-white">{item}</h3>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section
      id="contacto-servicio"
      class="relative overflow-hidden py-20 sm:py-24 lg:py-28 scroll-mt-32"
    >
      <div
        class="relative mx-auto w-full max-w-[1480px] px-4 sm:px-6 lg:px-10 2xl:max-w-[1600px]"
      >
        <div
          class="overflow-hidden rounded-[34px] border border-blue-300/15 bg-[#061126]/75 p-6 shadow-[0_0_65px_rgba(37,99,235,0.18)] backdrop-blur-xl sm:p-8 lg:p-12"
        >
          <div class="grid gap-8 lg:grid-cols-[1fr_0.6fr] lg:items-center">
            <div>
              <p
                class="text-xs font-semibold uppercase tracking-[0.32em] text-blue-300"
              >
                Agenda una revisión
              </p>

              <h2
                class="mt-4 max-w-4xl text-3xl font-bold tracking-[-0.04em] text-white sm:text-4xl md:text-5xl"
              >
                ¿Quieres saber si este servicio aplica para tu negocio?
              </h2>

              <p
                class="mt-5 max-w-3xl text-sm leading-7 text-slate-300 sm:text-base sm:leading-8"
              >
                Escríbenos y revisamos tu caso. La idea no es venderte algo
                innecesario, sino entender qué problema tienes y qué solución
                tendría más sentido implementar.
              </p>
            </div>

            <div class="flex flex-col gap-4">
              <a
                href="https://wa.me/526142414255"
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center justify-center gap-2 rounded-xl border border-blue-300/20 bg-gradient-to-r from-[#1d4ed8] to-[#2563eb] px-7 py-4 text-sm font-bold text-white shadow-[0_0_34px_rgba(37,99,235,0.40)] transition-all duration-300 hover:-translate-y-0.5 hover:from-blue-500 hover:to-blue-400"
              >
                Contactar por WhatsApp
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 12h14"></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m12 5 7 7-7 7"></path>
                </svg>
              </a>

              <a
                href="/#servicios"
                class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.03] px-7 py-4 text-sm font-semibold text-white transition-all duration-300 hover:border-blue-300/30 hover:bg-blue-500/10"
              >
                Ver otros servicios
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
